{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.js",
    "tests/**/*.js",
    "scripts/**/*.js",
    "examples/**/*.js",
    "vitest.config.js"
  ],
  "exclude": ["node_modules", "dist", "coverage", "data", "tests/tmp"]
}
